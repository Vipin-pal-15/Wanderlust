<% layout("/layout/boilerplate") %>
<div class="row mt-3">
  <div class="col-8 offset-3">
<h3><%= listing.title %></h3>
</div>

<div class="card col-6 offset-3 show-card">
  <img src="<%= listing.image.url  %>" class="card-img-top show-img" alt="listing_image" />
  <div class="card-body">
      <p><i>Owned by <%= listing.owner.username  %></i></p>
    <p><%= listing.description %> </p>
    <p> &#8377;<%= listing.price.toLocaleString("en-IN") %> </p>
     <p><%= listing.location %> </p>
    <p> <%= listing.country %></p>
  </div>
  </div>
  </div>
 <div class="btns">
<a href="/listings/<%= listing._id %>/edit" class="btn btn-dark col-1 offset-3 add-btn">Edit</a>
<form method="POST" action="/listings/<%= listing._id  %>?_method=DELETE">
  <button class="btn btn-dark offset-4">Delete</button>
</form>
 </div>

 <div class="col-8 offset-3">
  <hr>
  <h4>Leave a Review</h4>
  <form class="mb-3" action="/listings/<%= listing.id %>/reviews" method="post" >
    <div class="mb-3 mt-3">
      <label for="ratinng" class="form-label">Rating</label>
      <!-- <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range"> -->
    </div>
    <fieldset class="starability-slot">
  <legend>First rating:</legend>
  <input type="radio" id="no-rate" class="input-no-rate" name="rating" value="0" checked aria-label="No rating." />
  <input type="radio" id="first-rate1" name="rating" value="1" />
  <label for="first-rate1" title="Terrible">1 star</label>
  <input type="radio" id="first-rate2" name="rating" value="2" />
  <label for="first-rate2" title="Not good">2 stars</label>
  <input type="radio" id="first-rate3" name="rating" value="3" />
  <label for="first-rate3" title="Average">3 stars</label>
  <input type="radio" id="first-rate4" name="rating" value="4" />
  <label for="first-rate4" title="Very good">4 stars</label>
  <input type="radio" id="first-rate5" name="rating" value="5" />
  <label for="first-rate5" title="Amazing">5 stars</label>
</fieldset>

    <div class="mb-3 mt-3">
      <label for="comment">Comments</label>
      <textarea name="review[comment]" id="comment" cols="30" rows="3" class="form-control" required></textarea>
      <div class="invalid-feedback">Please add some comments for review</div>
    </div>
    <button class="btn btn-outline-dark">Submit</button>
  </form>

 <p><b>All Reviews</b></p>
  <% for(review of listing.reviews)  {%>
    <p><%= review.comment  %>, <%= review.rating  %>stars</p>
    <h3>Rated element name</h3>
  <p class="starability-result card-text" data-rating="<%= review.rating  %>"></p>
    <% }  %>
    <!-- <%= listing.reviews  %> -->

<hr>
 </div>
 <div class="col-8 offset-3 mb-3">
  <h3>Where you'll be</h3>

  <style>
    #map{
      height: 400px;
      width: 100%;
    }
  </style>
  <div id="map">
    <script>
  var map = L.map('map').setView([26.8467, 80.9462],11);

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenStreetMap'
  }).addTo(map);

  L.marker([26.8467, 80.9462]).addTo(map)
    .bindPopup(`
  <b style="font-size:16px;">🌍 Wanderlust</b><br>
  <span style="color:blue;">Vipin Pal ✨</span><br>
  <span style="color:gray;">Cutated Travel Experience🌐</span>
`)
    .openPopup();
</script>
  </div>
</div>
 </div>
 <br><br>
 